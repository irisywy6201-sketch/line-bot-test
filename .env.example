# YouTube Data API v3 金鑰
# 取得方式：Google Cloud Console → 建立專案 → 啟用 YouTube Data API v3 → 建立 API 金鑰
YOUTUBE_API_KEY=
# LINE Messaging API
# 取得方式：https://developers.line.biz → 選擇你的 channel → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=

# 你的 LINE User ID（接收每日推送用）
# 取得方式：LINE Developers Console → 右上角頭像 → 你的 User ID（U 開頭）
LINE_USER_ID=

# LINE Channel Secret（Webhook 簽名驗證用）
# 取得方式：LINE Developers Console → 你的 channel → Basic settings → Channel secret
LINE_CHANNEL_SECRET=
# Gemini API 金鑰（用於生成內容總結）
# 取得方式：https://aistudio.google.com → Get API key
GEMINI_API_KEY=
